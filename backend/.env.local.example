# Backend 로컬 개발 환경 설정 예시
# 이 파일을 .env로 복사하여 사용하세요: cp .env.local.example .env

# ===========================================
# 필수 설정
# ===========================================
PORT=3001
APPIUM_URL=http://localhost:4900

# ===========================================
# 개발 모드 인증 우회 (선택)
# ===========================================
# Slack OAuth 없이 개발 가능
AUTH_BYPASS=true
DEV_USER_NAME=Developer
DEV_USER_EMAIL=dev@local.test

# ===========================================
# Slack OAuth (개발 모드 비활성 시 필요)
# ===========================================
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_REDIRECT_URI=http://localhost:3001/api/auth/slack/callback

# ===========================================
# JWT 설정 (선택 - 미설정 시 자동 생성)
# ===========================================
# JWT_SECRET=your-32-character-secret-key-here

# ===========================================
# Cloudflare R2 (선택 - 비활성화 가능)
# ===========================================
R2_ENABLED=false
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=

# ===========================================
# Slack 알림 (선택)
# ===========================================
# SLACK_WEBHOOK_URL=

# ===========================================
# Google Cloud Vision OCR (선택)
# ===========================================
# GOOGLE_APPLICATION_CREDENTIALS=path/to/credentials.json
